{
  "name": "Harness Log",
  "scopeName": "text.harness-log",
  "patterns": [
    {
      "match": "^.*\\b(ERROR|ERRO|FAIL|FATAL|âś—)\\b.*$",
      "name": "markup.deleted"
    },
    {
      "match": "^.*\\b(WARN|WARNING|âš )\\b.*$",
      "name": "markup.changed"
    },
    {
      "match": "^.*\\b(SUCCESS|PASS|DONE|âś“)\\b.*$",
      "name": "markup.inserted"
    },
    {
      "match": "^.*\\bINFO\\b.*$",
      "name": "comment"
    },
    {
      "match": "^.*\\b(DEBUG|TRACE)\\b.*$",
      "name": "comment.block"
    },
    {
      "match": "^\\s*\\d+\\s",
      "name": "constant.numeric"
    },
    {
      "match": "\\d{2}:\\d{2}:\\d{2}",
      "name": "string"
    },
    {
      "match": "^#.*$",
      "name": "comment.line"
    }
  ]
}
